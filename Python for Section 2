import os
import shutil
import numpy as np
import matplotlib.pyplot as plt
import networkx as nx
from google.colab import files

# Enforce strictly 64-bit precision for physical constraints
np.set_printoptions(precision=16)

FIG_DIR = 'paper3_section2_figures'
os.makedirs(FIG_DIR, exist_ok=True)

def save_fig(fig, filename):
    filepath = os.path.join(FIG_DIR, filename)
    fig.savefig(filepath, dpi=300, bbox_inches='tight')
    print(f"Saved: {filepath}")

# Figure 1: Polynomial Payoffs vs Quadratic Payoffs
def plot_polynomial_payoffs():
    fig, ax = plt.subplots(figsize=(8, 6))
    
    # Gradient deviation zeta = (grad u_i - grad u_j)
    zeta = np.linspace(-2.5, 2.5, 500, dtype=np.float64)
    
    # 1. Standard Linear/Quadratic penalty (m=1) from RGB games
    gamma_1 = 1.0
    cost_quadratic = gamma_1 * zeta**2
    
    # 2. Hyperspectral Polynomial penalty (d=3)
    # Modeling non-linear scattering severity
    gamma_2, gamma_3 = 0.5, 0.15 
    cost_polynomial = gamma_1 * zeta**2 + gamma_2 * zeta**4 + gamma_3 * zeta**6
    
    ax.plot(zeta, cost_quadratic, color='#3498db', linewidth=3, linestyle='--', label=r'Quadratic Coupling ($m=1$)')
    ax.plot(zeta, cost_polynomial, color='#e74c3c', linewidth=3.5, label=r'Polynomial Coupling ($d=3$)')
    
    # Annotations for physical interpretation
    ax.fill_between(zeta, cost_quadratic, cost_polynomial, where=(np.abs(zeta) > 1.5), 
                    color='#e74c3c', alpha=0.15, label='Exponential Penalty Zone (Severe Mixing)')
                    
    ax.axvline(0, color='black', linewidth=1, alpha=0.5)
    ax.axhline(0, color='black', linewidth=1, alpha=0.5)
    
    ax.set_title("Algebraic Visualization of Polynomial Spectral Coupling", fontweight='bold', pad=15)
    ax.set_xlabel(r"Structural Deviation $\zeta = \nabla u_i - \nabla u_j$")
    ax.set_ylabel(r"Interaction Cost $J_{i,j}$")
    ax.set_ylim(-1, 25)
    ax.legend(loc='upper center')
    ax.grid(True, linestyle=':', alpha=0.7)
    
    save_fig(fig, "fig_polynomial_payoffs.png")
    plt.close()

# Figure 2: The Hyperspectral Polymatrix Network Topology
def plot_polymatrix_network():
    fig, ax = plt.subplots(figsize=(8, 8))
    
    # Simulate a 10-band hyperspectral subset for visualization
    N_bands = 10
    G = nx.complete_graph(N_bands)
    
    # Circular layout to represent the spectral sequence
    pos = nx.circular_layout(G)
    
    # Color map representing spectral bands (e.g., Blue to Near-Infrared)
    colors = plt.cm.jet(np.linspace(0, 1, N_bands))
    
    # Draw nodes (Spectral Bands)
    nx.draw_networkx_nodes(G, pos, node_color=colors, node_size=1500, edgecolors='black', linewidths=2)
    
    # Create labels for bands
    labels = {i: f"Band\n{i+1}" for i in range(N_bands)}
    nx.draw_networkx_labels(G, pos, labels, font_size=9, font_weight='bold', font_color='white')
    
    # Draw edges with varying thickness to represent the Adjacency Matrix A_{ij}
    np.random.seed(42)
    edges = G.edges()
    weights = []
    for u, v in edges:
        # Simulate physical correlation: closer bands have higher mutual information
        distance = min(abs(u - v), N_bands - abs(u - v))
        weight = np.exp(-0.5 * distance) + np.random.uniform(0, 0.2)
        weights.append(weight * 5) # Scale for visual thickness
        
    nx.draw_networkx_edges(G, pos, edgelist=edges, width=weights, edge_color='gray', alpha=0.4)
    
    # Add a bounding box annotation to explain the edges
    ax.text(0, -1.3, r"Edges represent Pairwise Polynomial Games $A_{ij} J_{i,j}$", 
            ha='center', va='center', fontsize=11, fontweight='bold', 
            bbox=dict(facecolor='white', edgecolor='black', boxstyle='round,pad=0.5'))
            
    ax.set_title(r"$N$-Player Hyperspectral Polymatrix Topology", fontweight='bold', pad=20, fontsize=14)
    ax.axis('off')
    
    save_fig(fig, "fig_polymatrix_network.png")
    plt.close()

# Execute generators
plot_polynomial_payoffs()
plot_polymatrix_network()

# Compress and ready for download
zip_filename = "Paper3_Section2_Figures"
shutil.make_archive(zip_filename, 'zip', FIG_DIR)
